# =============================================================================
# ParksDB environment template.
#
# Every value below is a SAFE-TO-COMMIT placeholder, NOT a real secret.
# To use:
#   1. cp server/.env.example server/.env
#   2. Edit server/.env with your actual values.
#   3. .env is gitignored — never commit it.
#
# In production: rotate all secrets, never use the placeholders below, and
# the app will refuse to boot with the dev defaults (see src/config.js).
# =============================================================================

# --- Server ---
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (no spaces)
CORS_ORIGINS=http://localhost:5173

# --- Database ---
# Either DATABASE_URL OR the discrete PG* vars below
DATABASE_URL=postgres://parksdb:parksdb_dev@localhost:5432/parksdb

# --- Auth ---
# IMPORTANT: replace with a long random string in production
JWT_SECRET=replace-me-with-a-long-random-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# --- CAPTCHA ---
# hCaptcha keys. Use the test keys below to exercise the flow without a real account.
# Real keys: https://www.hcaptcha.com/
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000
HCAPTCHA_SITEKEY=10000000-ffff-ffff-ffff-000000000001
# Set to "true" to skip CAPTCHA verification entirely (dev only!)
CAPTCHA_DISABLED=true

# --- Seed / bootstrap admin ---
SEED_ADMIN_EMAIL=admin@parksdb.local
SEED_ADMIN_PASSWORD=ChangeMe!123
