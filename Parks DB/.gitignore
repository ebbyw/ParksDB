# Dependencies / build artifacts
node_modules/
dist/
build/
coverage/
.next/
.cache/

# Environment files — NEVER commit. .env.example is the only env file that
# should land in the repo (and it must contain only placeholders).
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Certificates and keys — anything that looks like a credential
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa*
id_ed25519*

# Database dumps
*.sql.gz
*.dump
pgdata/
